{
  "name": "opikprobe",
  "version": "0.1.0",
  "description": "Local-first MCP telemetry fixture probe for deterministic trace and eval integration checks.",
  "type": "module",
  "bin": {
    "opikprobe": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "fixtures",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/src/cli.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "smoke": "npm run build && node dist/src/cli.js inspect fixtures/pass --output .tmp/smoke && node dist/src/cli.js inspect fixtures/fail --format json --output .tmp/fail --fail-on-violation=false",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "mcp",
    "observability",
    "opik",
    "telemetry",
    "fixtures",
    "local-first"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=20.11"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/opikprobe.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/opikprobe/issues"
  },
  "homepage": "https://github.com/rogerchappel/opikprobe#readme"
}
